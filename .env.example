# LinkShort Environment-Variablen
# Diese Datei nach .env kopieren und Werte anpassen.

# Server
PORT=3000
NODE_ENV=development

# Datenbank
#
# WICHTIG: DATABASE_URL wird NUR genutzt wenn USE_DATABASE_URL=true.
# Lokal/CI: USE_DATABASE_URL=false → PG*-Variablen greifen.
# Production: USE_DATABASE_URL=true als Render-Secret + DATABASE_URL setzen.
# Neon lokal testen: USE_DATABASE_URL=true temporär in .env.
#
# Production (Render/Neon): DATABASE_URL + USE_DATABASE_URL=true als Secrets setzen
# DATABASE_URL=postgresql://user:pass@host:5432/linkshort
#
# Lokal (Unix-Socket, Peer-Auth):
PGHOST=/var/run/postgresql
PGPORT=5432
PGDATABASE=linkshort
PGUSER=your-local-pg-user
PGPASSWORD=
USE_DATABASE_URL=false

# Auth (required)
JWT_SECRET=replace-with-a-long-random-string
SESSION_EXPIRY=86400

# Email (Feedback-Notifications via Gmail SMTP)
# Gmail App-Passwort: Google-Account → Sicherheit → App-Passwörter (2FA erforderlich)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=deine-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
FROM_EMAIL=deine-gmail@gmail.com
TO_EMAIL=empfaenger@example.com

# Optional
ANTHROPIC_API_KEY=sk-ant-dein-key-hier
LOG_LEVEL=info
RATE_LIMIT_MAX=100
